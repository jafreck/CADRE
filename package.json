{
  "name": "@cadre-dev/cadre",
  "version": "0.2.4",
  "description": "Coordinated Agent Development Runtime Engine",
  "license": "MIT",
  "author": "Jacob Freck",
  "repository": {
    "type": "git",
    "url": "https://github.com/jafreck/CADRE.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "src/agents/templates/"
  ],
  "bundledDependencies": [
    "@cadre-dev/framework",
    "@cadre-dev/runtime-provider-docker",
    "@cadre-dev/runtime-provider-kata"
  ],
  "bin": {
    "cadre": "dist/index.js"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present && tsc",
    "postbuild": "mkdir -p dist/agents && rm -rf dist/agents/templates && cp -r src/agents/templates dist/agents/templates",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:e2e": "CADRE_E2E=1 vitest run tests/e2e-*.test.ts"
  },
  "dependencies": {
    "@cadre-dev/framework": "*",
    "@cadre-dev/runtime-provider-docker": "*",
    "@cadre-dev/runtime-provider-kata": "*",
    "@inquirer/prompts": "^8",
    "@jafreck/lore": "^0.3.7",
    "@modelcontextprotocol/sdk": "^1.27",
    "@octokit/rest": "^22",
    "chalk": "^5",
    "commander": "^14",
    "date-fns": "^4",
    "ora": "^9",
    "p-limit": "^7",
    "p-queue": "^9",
    "simple-git": "^3.32",
    "zod": "^3.25",
    "zod-to-json-schema": "^3.25"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@vitest/coverage-v8": "^4",
    "tsx": "^4",
    "typescript": "^5.9",
    "vitest": "^4"
  }
}
