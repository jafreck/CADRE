{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@cadre-dev/framework": ["packages/framework/src/index.ts"],
      "@cadre-dev/framework/*": [
        "packages/framework/src/*/index.ts",
        "packages/framework/src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "packages/framework/src/**/*",
    "packages/runtime-provider-docker/src/**/*",
    "packages/runtime-provider-kata/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "tests"]
}
